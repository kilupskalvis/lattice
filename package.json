{
	"name": "lattice-graph",
	"version": "0.1.0",
	"description": "Knowledge graph CLI for coding agents — navigate code through flows, not grep.",
	"module": "src/main.ts",
	"type": "module",
	"bin": {
		"lattice": "src/main.ts"
	},
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"dev": "bun src/main.ts",
		"test": "bun test",
		"lint": "bunx biome check src/ tests/",
		"format": "bunx biome check --write src/ tests/",
		"typecheck": "bun tsc --noEmit",
		"check": "bun run lint && bun run typecheck && bun run test",
		"build": "bun build src/main.ts --compile --outfile lattice",
		"prepare": "bunx lefthook install"
	},
	"keywords": [
		"cli",
		"knowledge-graph",
		"coding-agent",
		"code-navigation",
		"lsp",
		"language-server",
		"static-analysis"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kilupskalvis/lattice"
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "latest",
		"lefthook": "^2.1.4"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"smol-toml": "^1.6.0"
	}
}
